<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <Button
        android:id="@+id/btn_clean_ram"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Clean RAM" />

    <Button
        android:id="@+id/btn_close_background_apps"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Close Background Apps" />

    <Button
        android:id="@+id/btn_launch_free_fire"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Launch Free Fire MAX" />

    <TextView
        android:id="@+id/status_display"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Status: Ready to Go!"
        android:textSize="16sp" />

</LinearLayout>